# ── Local development ──
# Relative URL — Vite's dev proxy (vite.config.ts) forwards /api to localhost:5000.
# Works for localhost AND any tunnel (ngrok, Cloudflare) without changing this file.
VITE_API_BASE_URL=/api

# Direct backend URL for Socket.io (the dev proxy does not handle WS here).
VITE_SOCKET_URL=http://localhost:5000

# ── Production (Render) ──
# These vars are baked into the bundle at BUILD time, so set them in the Render
# dashboard / render.yaml BEFORE the build runs. There is no Vite proxy in prod,
# so VITE_API_BASE_URL must be the FULL backend URL, not /api. Example:
#   VITE_API_BASE_URL=https://ftrace-backend.onrender.com/api
#   VITE_SOCKET_URL=https://ftrace-backend.onrender.com

# Multi-tenant subdomain resolution (utils/tenant.ts). Set to your apex domain
# (no scheme, no subdomain) so that tenant.yourdomain.com resolves to "tenant".
# Requires a custom domain + wildcard DNS — does NOT work on *.onrender.com.
# Without it, tenants are addressed via the ?tenant=slug query param.
#   VITE_BASE_DOMAIN=yourdomain.com
