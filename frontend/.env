# Relative URL — Vite proxies /api to localhost:5000.
# Works for localhost AND any tunnel (ngrok, Cloudflare) without changing this file.
VITE_API_BASE_URL=/api

# Direct backend URL for Socket.io (bypasses the Vite proxy to avoid WS conflicts).
# For localhost: keep as-is.
# For tunnels where the backend is also exposed: set to the backend tunnel URL,
#   e.g. VITE_SOCKET_URL=https://backend.ngrok-free.app
VITE_SOCKET_URL=http://localhost:5000
